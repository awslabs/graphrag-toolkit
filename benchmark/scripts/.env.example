# GraphRAG Benchmark Environment Variables
# Copy this file to .env and fill in your values before running scripts.

# Neptune cluster endpoint (e.g., your-cluster.cluster-xxxxx.us-west-2.neptune.amazonaws.com)
NEPTUNE_ENDPOINT=

# OpenSearch Serverless endpoint (e.g., xxxxx.us-west-2.aoss.amazonaws.com)
OPENSEARCH_ENDPOINT=

# AWS region for all service calls
AWS_REGION=us-west-2

# S3 URI containing benchmark datasets (extracted docs + QA files)
BENCHMARK_DATA_S3_URI=s3://ouss-benchmarking-tests/benchmark-data/

# S3 URI for storing benchmark results
RESULTS_S3_URI=s3://ouss-benchmarking-tests/

# S3 bucket name (without s3:// prefix)
BUCKET_NAME=ouss-benchmarking-tests

# LLM model ID for extraction phase (batch inference)
TEST_EXTRACTION_LLM=us.anthropic.claude-haiku-4-5-20251001-v1:0

# LLM model ID for response generation during query phase
TEST_RESPONSE_LLM=us.anthropic.claude-haiku-4-5-20251001-v1:0

# LLM model ID for evaluation judge (correctness + IDK grading)
BENCHMARK_JUDGE_LLM=us.anthropic.claude-sonnet-4-6

# Stack prefix used for CloudFormation stack naming and S3 result paths
STACK_PREFIX=

# Neptune instance type (default: db.r8g.2xlarge)
NEPTUNE_INSTANCE_TYPE=db.r8g.2xlarge

# SageMaker notebook instance type (use ml.m5.4xlarge for ConcurrentQA/WikiHow, ml.m5.xlarge for CUAD/PGA)
NOTEBOOK_INSTANCE_TYPE=ml.m5.xlarge

# --- VPC Reuse (optional) ---
# Set both to reuse an existing VPC across multiple benchmark stacks.
# This avoids hitting the 10 VPC limit when running datasets in parallel.
# Leave empty to create a new VPC per stack (default behavior).
EXISTING_VPC_ID=
EXISTING_SUBNET_IDS=
