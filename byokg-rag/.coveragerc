[run]
source = src/graphrag_toolkit/byokg_rag
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */prompts/*

[report]
show_missing = true
skip_empty = true
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
