# Environment Configuration for Lexical Graph Workshop
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# Examples:
# For Neptune Analytics: 
# GRAPH_STORE=wss://g-abc123.us-east-1.neptune-graph.amazonaws.com/
# For Neptune Database:
# wss://my-cluster.cluster-abc123.us-east-1.neptune.amazonaws.com:8182/gremlin
# Examples:
#   Neptune Analytics: wss://g-abc123.us-east-1.neptune-graph.amazonaws.com/
#   Neptune Database: wss://my-cluster.cluster-abc123.us-east-1.neptune.amazonaws.com:8182/gremlin
#   Neo4j: bolt://username:password@localhost:7687
GRAPH_STORE=

# Vector Database connection string
# Examples:
#   Neptune Analytics: wss://g-abc123.us-east-1.neptune-graph.amazonaws.com/
#   PostgreSQL (pgvector): postgresql://user:password@localhost:5432/dbname
VECTOR_STORE=

# Bedrock Models
EXTRACTION_MODEL=us.anthropic.claude-sonnet-4-6
RESPONSE_MODEL=us.anthropic.claude-sonnet-4-6
